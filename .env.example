# LiveKit Cloud (auto-injected when deploying via `lk app deploy`).
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Direct provider keys — Lisa uses each provider's own SDK, NOT the LK gateway.
# Required: missing keys cause STT/LLM/TTS to fail at session start.
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ELEVEN_API_KEY=

# CRM webhook (n8n). When unset, tool outcomes still emit structured logs but
# are NOT pushed to the CRM. Production deploys must set this.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_TIMEOUT_S=5.0
N8N_WEBHOOK_MAX_RETRIES=3
N8N_WEBHOOK_FAILURE_LOG=/tmp/lisa-crm-failed-writes.jsonl

# Health endpoint port (Coolify/k8s liveness probe). Default 8080.
HEALTH_PORT=8080
